<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit </title>
</head>
<body>
    <form action="/listings/<%=listing._id%>?_method=PATCH" method="post">
        <input type="text" name="listing[title]" id="title" placeholder="Enter your title"> <br> <br>
        <textarea name="listing[description]" id="description" placeholder="Enter your description"></textarea>
<br> <br>
        <input type="number" name="listing[price]" id="price" placeholder="Enter your place rent"><br> <br>
        <input type="text" name="listing[image]" id="image"  placeholder="Paste image link Here"> <br> <br>
        <input type="text" name="listing[location]" id="location" placeholder="Enter your location"> <br> <br>
        <input type="text" name="listing[country]" id="country" placeholder="Enter your country"> <br> <br>
        <button>edit</button>
    </form>
    
</body>
</html>