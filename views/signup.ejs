<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SignUP</title>
</head>
<body>
    <form action="/signup/success" method="post">
        <input type="text" name="user[username]" id="username" minlength="8" maxlength="20">
        <input type="email" name="user[email]" id="email">
        <input type="password" name="user[password]" id="password" minlength="6" maxlength="14">
        <button>Singup</button>
    </form>
</body>
</html>